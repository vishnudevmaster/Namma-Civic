# GEMINI_API_KEY: Required for Gemini AI chatbot.
# Get a key from https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# GOOGLE_MAPS_KEY: Required for Google Places Autocomplete in the location picker.
# Get a key from https://console.cloud.google.com/apis/credentials
# Enable the "Places API" and "Maps JavaScript API" for your project.
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# CLERK: Required for authentication.
# Sign up at https://clerk.com and get keys from the Dashboard > API Keys.
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# SUPABASE: Required for the PostgreSQL database.
# Create a project at https://supabase.com and get keys from Settings > API.
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# CLOUDINARY: Required for image upload storage.
# Sign up at https://cloudinary.com and get credentials from the Dashboard > Settings > API Keys.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
